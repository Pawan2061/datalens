# ============================================================================
# DataLens Analytics — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────
# Options: "mock" (no API key needed), "openai", "azure", "anthropic"
LLM_PROVIDER=openai

# ── OpenAI (when LLM_PROVIDER=openai) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_PLANNER_MODEL=gpt-4o
OPENAI_WORKER_MODEL=gpt-4.1-mini

# ── Azure OpenAI (when LLM_PROVIDER=azure) ───────────────────────────
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-azure-api-key
AZURE_PLANNER_DEPLOYMENT=gpt-4o
AZURE_WORKER_DEPLOYMENT=gpt-4.1-mini
AZURE_API_VERSION=2025-01-01-preview

# ── Anthropic (when LLM_PROVIDER=anthropic) ──────────────────────────
# Option A — direct API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Option B — Azure AI Foundry (leave blank if using Option A)
ANTHROPIC_FOUNDRY_KEY=
ANTHROPIC_FOUNDRY_URL=
ANTHROPIC_PLANNER_MODEL=claude-sonnet-5
ANTHROPIC_WORKER_MODEL=claude-haiku-4-5
ANTHROPIC_AGENT_MAX_TOKENS=2048
ANTHROPIC_CONVERSATIONAL_MAX_TOKENS=700
ANTHROPIC_SYNTHESIS_MAX_TOKENS=1400
ANTHROPIC_PLANNER_MAX_TOKENS=4096

# ── Google Gemini (free tier — used for guardrails classifier) ───────
GOOGLE_API_KEY=your-google-api-key

# ── Experimental: API-tools-only Ollama/Gemma pre-pass ───────────────
# Disabled by default. When true, only workspace API-tool selection is tried
# with local Ollama first if API_TOOLS_OLLAMA_ROUTER_ENABLED=true. By default,
# the main LLM still calls tools and Ollama only post-processes API results.
API_TOOLS_OLLAMA_ENABLED=false
API_TOOLS_OLLAMA_ROUTER_ENABLED=false
API_TOOLS_OLLAMA_PROCESS_RESULTS_ENABLED=true
API_TOOLS_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
API_TOOLS_OLLAMA_MODEL=gemma4:e4b
API_TOOLS_OLLAMA_TIMEOUT_SECONDS=90
API_TOOLS_OLLAMA_PROCESSING_TIMEOUT_SECONDS=30

# ── Authentication ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-in-production
ADMIN_EMAIL=your-admin@example.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google reCAPTCHA v2 — get keys at https://www.google.com/recaptcha/admin
# Type: reCAPTCHA v2 "I'm not a robot" Checkbox
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ── PostgreSQL (app persistence — Neon or any Postgres) ──────────────
DATABASE_URL=postgresql+psycopg://user:password@host/dbname

# ── Azure Cosmos DB (only needed if users connect a Cosmos data source) ──
# COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-primary-key
# COSMOS_DATABASE=DataLensDB

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5174"]

# ── Query Safety ─────────────────────────────────────────────────────
MAX_QUERY_TIMEOUT_SECONDS=30
MAX_QUERY_ROWS=10000

# ── Schema Cache ─────────────────────────────────────────────────────
SCHEMA_CACHE_TTL=600
RESPONSE_CACHE_TTL_SECONDS=3600
RESPONSE_CACHE_MAX_SIZE=200

# ── Mock Mode (when LLM_PROVIDER=mock) ───────────────────────────────
MOCK_LLM_DELAY_MS=500

# ── Email / SMTP (data export + cost alerts) ─────────────────────────
# Required for the $2 cost-alert email below to actually send. For Gmail,
# use an App Password (not your normal password).
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_SMTP_FROM=your-email@gmail.com
EMAIL_SMTP_TIMEOUT_SECONDS=30
# Use SSL for port 465. For port 587, keep SSL false and STARTTLS true.
EMAIL_SMTP_USE_SSL=false
EMAIL_SMTP_USE_STARTTLS=true

# ── Rate Limiting (per-user burst protection on /api/chat) ───────────
# In-memory sliding window; admins bypass. Set RATE_LIMIT_ENABLED=false
# to disable. Defaults are "balanced": ~15/min, ~150/hour per user.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=15
RATE_LIMIT_PER_HOUR=150

# ── Cost Alerts ──────────────────────────────────────────────────────
# Email the team when a user's spend in the current day (UTC) first crosses
# the threshold for their role. Fires at most once per user per day.
# Alert-only — users are not blocked. No-op unless SMTP above is configured.
# Recipients default to the AINocular team in code; the JSON-array env var
# below overrides them.
COST_ALERT_THRESHOLD_USD=2.0          # regular users
COST_ALERT_THRESHOLD_USD_ADMIN=10.0   # admins
COST_ALERT_RECIPIENTS=["vaibhav@ainocular.com","bhairav@ainocular.com","pawan@ainocular.com"]
